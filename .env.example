# ===================================================
# STOCKFLOW INVENTORY MVP ENVIRONMENT VARIABLES
# ===================================================

# Port for the Node.js Express backend to listen on (Default: 3001)
PORT=3001

# URL of the frontend React client (Default: http://localhost:5173)
CLIENT_URL=http://localhost:5173

# Secret key used for signing user session JWT tokens
JWT_SECRET=super-secret-jwt-key-12345

# Database Connection URL (PostgreSQL)
# Used by Prisma ORM for schema push and database synchronization.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/stockflow"
